{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Debug Wireframer (with Browser)",
      "program": "${workspaceFolder}/server.js",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "restart": true,
      "cwd": "${workspaceFolder}",
      "serverReadyAction": {
        "pattern": "Server running at http://localhost:(\\d+)",
        "uriFormat": "http://localhost:%s",
        "action": "openExternally"
      }
    }
  ]
}